---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar";
import Footer from "../components/Footer";
import {
  GlobeAltIcon,
  UserGroupIcon,
  MapPinIcon,
  BriefcaseIcon,
  BuildingLibraryIcon,
  BellAlertIcon,
  AcademicCapIcon,
  BuildingOffice2Icon,
  ClockIcon,
  ClipboardDocumentListIcon,
  HomeModernIcon,
} from "@heroicons/react/24/solid";

const baseUrl = import.meta.env.BASE_URL;
---

<Layout>
  <Navbar client:load />
  <!-- Hero Section - Banner 100 años -->
  <section
    class="relative w-full h-[60vh] sm:h-[75vh] md:h-screen overflow-visible"
  >
    <!-- Banner Image con animación de revelado -->
    <div class="banner-container w-full h-full pt-16 sm:pt-20 overflow-hidden">
      <img
        src={`${baseUrl}banner_100.png`}
        alt="Centenario Carabineros - 100 años de servicio"
        class="w-full h-full object-cover"
        style={{
          WebkitMaskImage:
            "linear-gradient(to bottom, rgba(0,0,0,1) 96%, rgba(0,0,0,0.8) 98%, rgba(0,0,0,0) 100%)",
          maskImage:
            "linear-gradient(to bottom, rgba(0,0,0,1) 94%, rgba(0,0,0,0.3) 97%, rgba(0,0,0,0) 100%)",
          WebkitMaskRepeat: "no-repeat",
          maskRepeat: "no-repeat",
          WebkitMaskSize: "100% 100%",
          maskSize: "100% 100%",
        }}
      />
    </div>

    <!-- Logo Carabineros posicionado mitad y mitad -->
    <div
      class="absolute -bottom-18 sm:-bottom-25 md:-bottom-30 lg:-bottom-40 left-1/2 z-20 animate-fade-in-logo"
    >
      <img
        src={`${baseUrl}logo_carabineros.svg`}
        alt="Logo Carabineros de Chile"
        class="w-40 h-auto sm:w-52 md:w-64 lg:w-80 drop-shadow-2xl"
      />
    </div>
  </section>

  <!-- Historia de Carabineros -->
  <section
    class="pt-20 sm:pt-28 md:pt-40 lg:pt-48 pb-16 md:pb-24 bg-linear-to-t from-gray-50 to-white relative overflow-hidden"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8 relative z-10">
      <!-- Header -->
      <div class="text-center mb-12 md:mb-16">
        <div
          class="text-secondary-green font-semibold text-xs sm:text-sm uppercase tracking-[2px] mb-2"
        >
          NUESTRA HISTORIA
        </div>
        <h2
          class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-text-dark mb-3 md:mb-4"
        >
          100 Años de Servicio a Chile
        </h2>
        <p class="text-text-light max-w-3xl mx-auto text-base sm:text-lg px-4">
          Un siglo de compromiso, dedicación y servicio a la comunidad chilena
        </p>
      </div>

      <!-- Narrativa -->
      <div class="max-w-4xl mx-auto space-y-6 md:space-y-8">
        <!-- Párrafo 1: Fundación -->
        <div
          class="bg-white p-5 sm:p-6 md:p-8 rounded-xl md:rounded-2xl shadow-lg border-l-4 border-primary-green"
        >
          <p
            class="text-text-dark text-sm sm:text-base md:text-lg leading-relaxed"
          >
            <span class="text-primary-green font-bold text-xl sm:text-2xl"
              >E</span
            >l 27 de abril de 1927, bajo el gobierno del Presidente Carlos
            Ibáñez del Campo, nació <strong class="text-primary-green"
              >Carabineros de Chile</strong
            >, una institución que marcaría para siempre la historia de nuestro
            país. La fusión de la Policía Fiscal, el Cuerpo de Carabineros y el
            Regimiento de Carabineros dio origen a una institución unificada que
            se convertiría en el pilar fundamental del orden y la seguridad
            pública de la nación.
          </p>
        </div>

        <!-- Párrafo 2: Desarrollo y Modernización -->
        <div
          class="bg-white p-5 sm:p-6 md:p-8 rounded-xl md:rounded-2xl shadow-lg border-l-4 border-secondary-green"
        >
          <p
            class="text-text-dark text-sm sm:text-base md:text-lg leading-relaxed mb-3 md:mb-4"
          >
            A lo largo de las décadas siguientes, <strong
              >Carabineros se consolidó como una institución de vanguardia</strong
            >. Durante los años 50 y 60, se implementaron importantes avances
            tecnológicos y organizacionales que profesionalizaron la formación
            del personal y modernizaron los sistemas de comunicación. La
            institución se adaptó constantemente a los desafíos de cada época,
            manteniendo siempre su compromiso inquebrantable con el pueblo
            chileno.
          </p>
          <p
            class="text-text-dark text-sm sm:text-base md:text-lg leading-relaxed"
          >
            El periodo de transformación que vivió el país entre 1973 y 1990
            también marcó cambios significativos en la estructura y
            funcionamiento de la institución. Con el retorno a la democracia en
            1990, Carabineros inició un profundo proceso de modernización y
            adaptación a las nuevas necesidades de seguridad ciudadana en un
            contexto democrático, fortaleciendo su rol como garante del orden
            público y protector de los derechos de todas las personas.
          </p>
        </div>

        <!-- Párrafo 3: Era Moderna -->
        <div
          class="bg-white p-5 sm:p-6 md:p-8 rounded-xl md:rounded-2xl shadow-lg border-l-4 border-primary-green"
        >
          <p
            class="text-text-dark text-sm sm:text-base md:text-lg leading-relaxed mb-3 md:mb-4"
          >
            El siglo XXI trajo consigo la <strong
              >era digital y la transparencia institucional</strong
            >. Carabineros implementó tecnologías avanzadas y sistemas de
            gestión digital que revolucionaron la forma de entregar servicio a
            la comunidad. Se establecieron nuevos protocolos de derechos humanos
            y se fortaleció la relación con los ciudadanos, priorizando siempre
            el respeto, la cercanía y la eficiencia.
          </p>
        </div>

        <!-- Párrafo 4: Centenario -->
        <div
          class="bg-gradient-to-br from-primary-green to-secondary-green p-5 sm:p-6 md:p-8 rounded-xl md:rounded-2xl shadow-xl text-white"
        >
          <p
            class="text-sm sm:text-base md:text-lg leading-relaxed mb-3 md:mb-4"
          >
            <strong class="text-xl sm:text-2xl"
              >Hoy, al celebrar nuestro centenario</strong
            >, miramos con orgullo estos 100 años de historia. Un siglo en el
            que miles de hombres y mujeres han vestido el uniforme con honor,
            dedicando sus vidas al servicio de Chile. Cada patrullaje, cada
            emergencia atendida, cada mano amiga extendida a la comunidad, ha
            construido el legado que celebramos.
          </p>
          <p class="text-sm sm:text-base md:text-lg leading-relaxed">
            Este centenario no es solo una conmemoración del pasado, sino una
            renovación de nuestro compromiso con el futuro. <strong
              >Seguiremos siendo la institución cercana, confiable y profesional</strong
            > que Chile necesita, adaptándonos a los nuevos desafíos mientras mantenemos
            los valores que nos han guiado durante un siglo: honor, disciplina y servicio
            incondicional a la patria.
          </p>
        </div>
      </div>

      <!-- Cifras destacadas -->
      <div
        class="mt-16 md:mt-20 grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6"
      >
        <div
          class="text-center p-4 sm:p-5 md:p-6 bg-white rounded-lg md:rounded-xl shadow-md hover:shadow-lg transition-shadow"
        >
          <div
            class="text-3xl sm:text-4xl font-extrabold text-primary-green mb-2"
          >
            100
          </div>
          <div
            class="text-xs sm:text-sm text-text-light uppercase tracking-wide"
          >
            Años de Historia
          </div>
        </div>
        <div
          class="text-center p-4 sm:p-5 md:p-6 bg-white rounded-lg md:rounded-xl shadow-md hover:shadow-lg transition-shadow"
        >
          <div
            class="text-3xl sm:text-4xl font-extrabold text-primary-green mb-2"
          >
            16
          </div>
          <div
            class="text-xs sm:text-sm text-text-light uppercase tracking-wide"
          >
            Regiones
          </div>
        </div>
        <div
          class="text-center p-4 sm:p-5 md:p-6 bg-white rounded-lg md:rounded-xl shadow-md hover:shadow-lg transition-shadow"
        >
          <div
            class="text-3xl sm:text-4xl font-extrabold text-primary-green mb-2"
          >
            24/7
          </div>
          <div
            class="text-xs sm:text-sm text-text-light uppercase tracking-wide"
          >
            Servicio Continuo
          </div>
        </div>
        <div
          class="text-center p-4 sm:p-5 md:p-6 bg-white rounded-lg md:rounded-xl shadow-md hover:shadow-lg transition-shadow"
        >
          <div
            class="text-3xl sm:text-4xl font-extrabold text-primary-green mb-2"
          >
            ∞
          </div>
          <div
            class="text-xs sm:text-sm text-text-light uppercase tracking-wide"
          >
            Compromiso
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Ejes de Acción del Centenario - Banner Intro -->
  <section
    class="py-10 md:py-14 bg-gradient-to-r from-primary-green to-secondary-green"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8 text-center">
      <p
        class="text-white/80 text-xs sm:text-sm uppercase tracking-[3px] font-semibold mb-3"
      >
        PROGRAMA CENTENARIO 2027
      </p>
      <h2
        class="text-2xl sm:text-3xl md:text-4xl font-extrabold text-white mb-4"
      >
        Ejes de Acción del Centenario
      </h2>
      <p class="text-white/90 max-w-2xl mx-auto text-sm sm:text-base">
        Los pilares estratégicos que guían la transformación y modernización
        institucional hacia el segundo siglo de Carabineros de Chile
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-3 mt-6">
        <div
          class="bg-white/20 backdrop-blur-sm px-5 py-2.5 rounded-full text-white font-semibold text-sm border border-white/30"
        >
          <span class="opacity-75">Eje 1 —</span> Infraestructura Policial
        </div>
        <div
          class="bg-white/20 backdrop-blur-sm px-5 py-2.5 rounded-full text-white font-semibold text-sm border border-white/30"
        >
          <span class="opacity-75">Eje 2 —</span> Educación
        </div>
      </div>
    </div>
  </section>

  <!-- EJE DE ACCIÓN N°1: INFRAESTRUCTURA POLICIAL -->
  <section
    class="py-16 md:py-24 bg-gradient-to-br from-gray-50 to-white relative overflow-hidden"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8 relative z-10">
      <!-- Eje 1 Header -->
      <div class="flex items-start gap-4 md:gap-6 mb-10 md:mb-14">
        <div
          class="flex-shrink-0 w-14 h-14 bg-gradient-to-br from-primary-green to-secondary-green rounded-2xl flex items-center justify-center text-white font-extrabold text-2xl shadow-lg"
        >
          1
        </div>
        <div>
          <p
            class="text-secondary-green font-semibold text-xs sm:text-sm uppercase tracking-[2px] mb-1"
          >
            EJE DE ACCIÓN N°1
          </p>
          <h2
            class="text-2xl sm:text-3xl md:text-4xl font-extrabold text-text-dark leading-tight"
          >
            Infraestructura Policial
          </h2>
          <p class="text-xs sm:text-sm text-text-light mt-1.5">
            Jefe de Eje: <span class="font-semibold text-text-dark"
              >General Patricio Yañez Nahuelhuaique</span>
          </p>
        </div>
      </div>

      <!-- Descripción del Eje -->
      <div class="max-w-5xl mb-12">
        <div
          class="bg-gradient-to-r from-primary-green/10 to-secondary-green/10 p-5 md:p-6 rounded-xl border-l-4 border-primary-green"
        >
          <p class="text-text-dark text-sm sm:text-base leading-relaxed">
            Este eje busca desarrollar <strong
              >proyectos de infraestructura emblemáticos</strong
            > que representen la modernización policial y la presencia institucional
            en zonas estratégicas del país. Incluye proyectos de reposición, relocalización
            y construcción de nuevas unidades policiales con estándares de habitabilidad,
            eficiencia energética y resiliencia estructural.
          </p>
        </div>
      </div>

      <!-- Proyectos -->
      <div class="space-y-10 md:space-y-12">
        <!-- PROYECTO: Comisarías del Centenario -->
        <div
          class="bg-white rounded-2xl shadow-xl overflow-hidden border border-gray-100"
        >
          <div
            class="bg-gradient-to-r from-primary-green to-secondary-green px-6 md:px-8 py-5 flex items-center gap-4"
          >
            <BuildingOffice2Icon className="w-8 h-8 text-white flex-shrink-0" />
            <div>
              <h3 class="text-lg md:text-xl font-bold text-white">
                Proyecto Comisarías del Centenario
              </h3>
              <p class="text-white/80 text-xs sm:text-sm">
                Ejecutor: Jefe Departamento Cuarteles L.1.
              </p>
            </div>
          </div>
          <div class="p-6 md:p-8">
            <p class="text-text-light text-xs sm:text-sm mb-5">
              Estado de avance de las 5 comisarías emblemáticas del centenario:
            </p>
            <div class="space-y-3">
              <!-- 37ª Vitacura: 85% -->
              <div
                class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 p-4 bg-gray-50 rounded-xl border border-gray-100 hover:border-primary-green/30 transition-colors"
              >
                <div class="flex-1 min-w-0">
                  <p class="font-bold text-text-dark text-sm md:text-base">
                    37ª Comisaría Vitacura
                  </p>
                  <p class="text-xs text-text-light mt-0.5">
                    En ejecución de diseño · Etapa ¾ en revisión
                  </p>
                </div>
                <div class="flex items-center gap-3 flex-shrink-0">
                  <div
                    class="w-24 md:w-32 h-2.5 bg-gray-200 rounded-full overflow-hidden"
                  >
                    <div
                      class="h-full bg-primary-green rounded-full"
                      style="width: 85%"
                    >
                    </div>
                  </div>
                  <span class="text-sm font-extrabold text-primary-green w-9"
                    >85%</span
                  >
                </div>
              </div>
              <!-- 19ª Providencia -->
              <div
                class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 p-4 bg-gray-50 rounded-xl border border-gray-100 hover:border-amber-300 transition-colors"
              >
                <div class="flex-1 min-w-0">
                  <p class="font-bold text-text-dark text-sm md:text-base">
                    19ª Comisaría Providencia
                  </p>
                  <p class="text-xs text-text-light mt-0.5">
                    En gestión de convenio con la Municipalidad; anteproyecto
                    remitido, sin respuesta
                  </p>
                </div>
                <span
                  class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-semibold bg-amber-100 text-amber-700 flex-shrink-0"
                >
                  <ClockIcon className="w-3 h-3" />
                  En Gestión
                </span>
              </div>
              <!-- 53ª Lo Barnechea -->
              <div
                class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 p-4 bg-gray-50 rounded-xl border border-gray-100 hover:border-amber-300 transition-colors"
              >
                <div class="flex-1 min-w-0">
                  <p class="font-bold text-text-dark text-sm md:text-base">
                    53ª Comisaría Lo Barnechea
                  </p>
                  <p class="text-xs text-text-light mt-0.5">
                    En verificación de terreno para relocalización y preparación
                    de convenio
                  </p>
                </div>
                <span
                  class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-semibold bg-amber-100 text-amber-700 flex-shrink-0"
                >
                  <ClockIcon className="w-3 h-3" />
                  En Verificación
                </span>
              </div>
              <!-- 2ª Copiapó -->
              <div
                class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 p-4 bg-gray-50 rounded-xl border border-gray-100 hover:border-blue-300 transition-colors"
              >
                <div class="flex-1 min-w-0">
                  <p class="font-bold text-text-dark text-sm md:text-base">
                    2ª Comisaría Copiapó
                  </p>
                  <p class="text-xs text-text-light mt-0.5">
                    En formulación de proyecto para diseño en DEDEPRO-DIPLADECAR
                  </p>
                </div>
                <span
                  class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-blue-100 text-blue-700 flex-shrink-0"
                >
                  En Formulación
                </span>
              </div>
              <!-- 4ª Santa Bárbara -->
              <div
                class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 p-4 bg-gray-50 rounded-xl border border-gray-100 hover:border-red-200 transition-colors"
              >
                <div class="flex-1 min-w-0">
                  <p class="font-bold text-text-dark text-sm md:text-base">
                    4ª Comisaría Santa Bárbara
                  </p>
                  <p class="text-xs text-text-light mt-0.5">
                    No priorizado por la Zona Biobío
                  </p>
                </div>
                <span
                  class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-red-100 text-red-600 flex-shrink-0"
                >
                  Sin Priorizar
                </span>
              </div>
            </div>
            <div
              class="mt-5 p-3.5 bg-primary-green/5 rounded-lg border border-primary-green/20 flex items-center gap-2.5"
            >
              <ClipboardDocumentListIcon
                className="w-4 h-4 text-primary-green flex-shrink-0"
              />
              <p class="text-xs text-text-light">
                La <strong class="text-text-dark">Carta Gantt</strong> del proyecto
                se encuentra disponible mediante el código QR al final del informe.
              </p>
            </div>
          </div>
        </div>

        <!-- PROYECTO: Retén Antártica -->
        <div
          class="bg-white rounded-2xl shadow-xl overflow-hidden border border-gray-100"
        >
          <div
            class="bg-gradient-to-r from-slate-700 to-slate-900 px-6 md:px-8 py-5 flex items-center gap-4"
          >
            <GlobeAltIcon className="w-8 h-8 text-white flex-shrink-0" />
            <div>
              <h3 class="text-lg md:text-xl font-bold text-white">
                Proyecto Retén Antártica
              </h3>
              <p class="text-white/80 text-xs sm:text-sm">
                Ejecutor: Jefe Zona Magallanes
              </p>
            </div>
          </div>
          <div class="p-6 md:p-8">
            <p class="text-text-dark text-sm sm:text-base leading-relaxed mb-6">
              Iniciativa estratégica destinada a evaluar la factibilidad de una <strong
                >presencia institucional de Carabineros en el continente
                antártico</strong
              >, con enfoque científico, logístico y de rescate. Su objetivo no
              es ejercer soberanía directa, sino contribuir a la cooperación
              internacional chilena mediante personal especializado en montaña o
              frontera, en apoyo a tareas de investigación, rescate y control en
              la zona.
            </p>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-5">
              <div class="bg-slate-50 p-5 rounded-xl border border-slate-200">
                <p
                  class="text-xs text-text-light uppercase tracking-wider mb-3 font-bold"
                >
                  Estado Actual
                </p>
                <ul class="space-y-2.5">
                  <li
                    class="flex items-start gap-2 text-xs sm:text-sm text-text-dark"
                  >
                    <span
                      class="text-primary-green font-bold mt-0.5 flex-shrink-0"
                      >✓</span
                    >
                    Diagnóstico preliminar geopolítico, ambiental y operativo realizado
                  </li>
                  <li
                    class="flex items-start gap-2 text-xs sm:text-sm text-text-dark"
                  >
                    <span
                      class="text-primary-green font-bold mt-0.5 flex-shrink-0"
                      >✓</span
                    >
                    Visita planificada a Base Presidente Eduardo Frei Montalva
                  </li>
                  <li
                    class="flex items-start gap-2 text-xs sm:text-sm text-text-dark"
                  >
                    <span class="text-amber-500 font-bold mt-0.5 flex-shrink-0"
                      >→</span
                    >
                    Coordinaciones interinstitucionales en proceso
                  </li>
                </ul>
              </div>
              <div class="bg-slate-50 p-5 rounded-xl border border-slate-200">
                <p
                  class="text-xs text-text-light uppercase tracking-wider mb-3 font-bold"
                >
                  Alternativas en Evaluación
                </p>
                <div class="space-y-2.5">
                  <div
                    class="flex items-center gap-3 p-3 bg-white rounded-lg border border-slate-200"
                  >
                    <div
                      class="w-2.5 h-2.5 rounded-full bg-primary-green flex-shrink-0"
                    >
                    </div>
                    <p class="text-xs sm:text-sm text-text-dark">
                      Presencia institucional <strong>permanente</strong>
                    </p>
                  </div>
                  <div
                    class="flex items-center gap-3 p-3 bg-white rounded-lg border border-slate-200"
                  >
                    <div
                      class="w-2.5 h-2.5 rounded-full bg-secondary-green flex-shrink-0"
                    >
                    </div>
                    <p class="text-xs sm:text-sm text-text-dark">
                      Presencia <strong>temporal estacional</strong>
                    </p>
                  </div>
                </div>
              </div>
            </div>
            <div
              class="p-3.5 bg-amber-50 rounded-lg border border-amber-200 flex items-start gap-2.5"
            >
              <ClockIcon
                className="w-4 h-4 text-amber-600 flex-shrink-0 mt-0.5"
              />
              <p class="text-xs text-amber-800">
                Sin Carta Gantt asociada. Iniciativa en fase de recolección de
                antecedentes, pendiente de validación definitiva conforme a los
                resultados obtenidos en terreno y coordinaciones
                interinstitucionales.
              </p>
            </div>
          </div>
        </div>

        <!-- PROYECTO: Comisaría Rapa Nuí -->
        <div
          class="bg-white rounded-2xl shadow-xl overflow-hidden border border-gray-100"
        >
          <div
            class="bg-gradient-to-r from-secondary-green to-primary-green px-6 md:px-8 py-5 flex items-center gap-4"
          >
            <HomeModernIcon className="w-8 h-8 text-white flex-shrink-0" />
            <div>
              <h3 class="text-lg md:text-xl font-bold text-white">
                Proyecto Comisaría Rapa Nuí
              </h3>
              <p class="text-white/80 text-xs sm:text-sm">
                Ejecutor: Jefe Zona de Valparaíso
              </p>
            </div>
          </div>
          <div class="p-6 md:p-8">
            <p class="text-text-dark text-sm sm:text-base leading-relaxed mb-6">
              Proyecto orientado a <strong
                >recuperar las condiciones operativas y habitacionales</strong
              > de la 6ª Comisaría Rapa Nuí y sus viviendas anexas, fortaleciendo
              la presencia institucional en este territorio insular de alto valor
              estratégico y cultural para Chile.
            </p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div
                class="bg-gradient-to-br from-primary-green/10 to-secondary-green/10 p-5 rounded-xl border border-primary-green/20"
              >
                <p
