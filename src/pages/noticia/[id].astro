---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import Footer from '../../components/Footer';
import { proyectos, slugify } from '../../data/noticias';
import type { NoticiaProyecto } from '../../types/noticias';

export function getStaticPaths() {
  return proyectos.map(p => ({
    params: { id: `${slugify(p.titulo)}-${p.id}` },
    props: { noticia: p }
  }));
}

const noticia = Astro.props.noticia as NoticiaProyecto;
const base = import.meta.env.BASE_URL;
---

<Layout>
  <Navbar client:load />

  <main class="min-h-screen bg-linear-to-b from-white to-gray-50">

    <!-- Hero Section -->
    <div class="relative min-h-[520px] md:min-h-[640px] flex items-end overflow-hidden">
      {noticia.portada ? (
        <>
          <img
            src={`${base}${noticia.portada}`}
            alt={noticia.titulo}
            class="absolute inset-0 w-full h-full object-cover"
          />
          <div class="absolute inset-0 bg-linear-to-t from-black/90 via-black/50 to-black/10" />
        </>
      ) : (
        <>
          <div class="absolute inset-0 bg-linear-to-br from-primary-green via-secondary-green to-[#35AF6F]" />
          <div class="absolute inset-0 bg-linear-to-t from-black/60 to-transparent" />
          <span class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-9xl opacity-20 select-none pointer-events-none">{noticia.icon}</span>
        </>
      )}
      <div class="relative z-10 w-full max-w-5xl mx-auto px-6 pb-12 md:pb-16">
        <span class="inline-block bg-secondary-green/90 text-white text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full mb-4">
          {noticia.categoria}
        </span>
        <h1 class="text-3xl md:text-5xl font-extrabold text-white leading-tight mb-4 drop-shadow-lg">
          {noticia.titulo}
        </h1>
        <p class="text-white/80 text-base md:text-lg max-w-3xl leading-relaxed">
          {noticia.descripcion}
        </p>
        <p class="text-white/50 text-sm mt-3">{noticia.fecha}</p>
      </div>
    </div>

    <!-- Franja de fotos -->
    {(noticia.portada || (noticia.fotos && noticia.fotos.length > 0)) && (
      <div class="flex gap-1 h-40 md:h-56 overflow-hidden">
        {noticia.portada && (
          <div class="flex-1 overflow-hidden">
            <img
              src={`${base}${noticia.portada}`}
              alt="Portada"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
            />
          </div>
        )}
        {noticia.fotos && noticia.fotos.slice(0, 3).map((foto) => (
          <div class="flex-1 overflow-hidden">
            <img
              src={`${base}${foto}`}
              alt=""
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
            />
          </div>
        ))}
      </div>
    )}

    <!-- Contenido principal -->
    <div class="max-w-4xl mx-auto px-6 py-12 md:py-16">

      <!-- Detalle Completo -->
      <div class="prose prose-lg max-w-none text-slate-700 mb-10">
        <p class="text-lg leading-relaxed whitespace-pre-line">{noticia.detalleCompleto}</p>
      </div>

      <!-- Beneficios -->
      {noticia.beneficios && noticia.beneficios.length > 0 && (
        <div class="mb-10">
          <h2 class="text-2xl font-bold text-slate-800 mb-5 flex items-center gap-2">
            <span class="text-secondary-green">✦</span> Beneficios
          </h2>
          <ul class="grid grid-cols-1 md:grid-cols-2 gap-3">
            {noticia.beneficios.map((b) => (
              <li class="flex items-start gap-3 bg-green-50 rounded-xl px-4 py-3 border border-green-100">
                <span class="text-secondary-green font-bold mt-0.5">✓</span>
                <span class="text-slate-700 text-sm leading-snug">{b}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- Conclusion -->
      {noticia.conclusion && (
        <div class="mb-10 bg-primary-green/5 border-l-4 border-primary-green rounded-r-xl px-6 py-5">
          <p class="text-slate-700 text-base italic leading-relaxed">{noticia.conclusion}</p>
        </div>
      )}

      <!-- Galeria extra -->
      {noticia.fotos && noticia.fotos.length >= 1 && (
        <div class="mb-10">
          <h2 class="text-2xl font-bold text-slate-800 mb-5 flex items-center gap-2">
            <span class="text-secondary-green">✦</span> Galeria
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {noticia.fotos.map((foto) => (
              <button
                class="lightbox-trigger aspect-4/3 overflow-hidden rounded-2xl shadow-md cursor-zoom-in block w-full"
                data-src={`${base}${foto}`}
                type="button"
                aria-label="Ver imagen ampliada"
              >
                <img
                  src={`${base}${foto}`}
                  alt=""
                  class="w-full h-full object-cover hover:scale-105 transition-transform duration-500 pointer-events-none"
                />
              </button>
            ))}
          </div>
        </div>
      )}

      <!-- Video -->
      {noticia.videoDetalle && (
        <div class="mb-10">
          <h2 class="text-2xl font-bold text-slate-800 mb-5 flex items-center gap-2">
            <span class="text-secondary-green">✦</span> Video
          </h2>
          <div class="aspect-video rounded-2xl overflow-hidden shadow-lg">
            <video
              src={`${base}${noticia.videoDetalle}`}
              class="w-full h-full"
              controls
              playsinline
            />
          </div>
        </div>
      )}

      <!-- Boton volver -->
      <div class="pt-4">
        <a
          href={`${base}#noticias`}
          class="inline-flex items-center gap-2 text-secondary-green font-semibold hover:underline text-sm"
        >
          &larr; Volver a Noticias
        </a>
      </div>

    </div>
  </main>

  <!-- Lightbox modal -->
  <div
    id="lightbox"
    class="fixed inset-0 z-9999 bg-black/90 hidden items-center justify-center p-4"
    role="dialog"
    aria-modal="true"
  >
    <button
      id="lightbox-close"
      class="absolute top-4 right-4 text-white/70 hover:text-white transition-colors"
      aria-label="Cerrar"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-9 h-9" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    <img
      id="lightbox-img"
      src=""
      alt=""
      class="max-w-full max-h-[90vh] rounded-2xl shadow-2xl object-contain"
    />
  </div>

  <Footer client:load />
</Layout>

<script>
  const lightbox = document.getElementById('lightbox') as HTMLElement;
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const closeBtn = document.getElementById('lightbox-close') as HTMLButtonElement;

  document.querySelectorAll<HTMLButtonElement>('.lightbox-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const src = btn.dataset.src ?? '';
      lightboxImg.src = src;
      lightbox.classList.remove('hidden');
      lightbox.classList.add('flex');
      document.body.style.overflow = 'hidden';
    });
  });

  const closeLightbox = () => {
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
    lightboxImg.src = '';
    document.body.style.overflow = '';
  };

  closeBtn.addEventListener('click', closeLightbox);
  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });
</script>